# Environment URLs
STAGING_URL=https://www.saucedemo.com
PROD_URL=https://www.saucedemo.com

# Test credentials (never commit real values)
# SauceDemo standard_user credentials -- safe to use for testing only
TEST_USERNAME=standard_user
TEST_PASSWORD=secret_sauce

# Browser settings
HEADLESS=true
SLOW_MO=0
RECORD_VIDEO=false

# Timeouts (milliseconds)
DEFAULT_TIMEOUT=30000
NAVIGATION_TIMEOUT=60000
